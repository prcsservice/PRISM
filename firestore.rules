rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper Functions ===
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isTeacher() {
      return hasRole("teacher");
    }

    function isStudent() {
      return hasRole("student");
    }

    // === Users Collection ===
    match /users/{userId} {
      // Users can read their own data; teachers can read all users (for student discovery)
      allow read: if isOwner(userId) || isTeacher();
      allow create: if isOwner(userId);
      // Users can update their own doc (onboarding, deletion request, etc.)
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'createdAt'])); // Cannot change role or creation date
    }

    // === Students Collection ===
    match /students/{studentId} {
      allow read: if isOwner(studentId);

      // Student Profile
      match /profile/main {
        allow read: if isOwner(studentId) || isTeacher();
        allow create: if isOwner(studentId) && isStudent();
        allow update: if isOwner(studentId) && isStudent();
      }

      // Legacy profile path (migration support)
      match /profile/data {
        allow read: if isOwner(studentId) || isTeacher();
        allow write: if isOwner(studentId) && isStudent();
      }

      // Academic Data (teacher-writable, student-readable)
      match /academic/data {
        allow read: if isOwner(studentId) || isTeacher();
        allow write: if isTeacher();
      }

      // Daily Logs (student-writable, read by owner + teacher)
      match /dailyLogs/{logId} {
        allow read: if isOwner(studentId) || isTeacher();
        allow create: if isOwner(studentId) && isStudent()
          && request.resource.data.date is string
          && request.resource.data.sleepHours is number
          && request.resource.data.sleepHours >= 0
          && request.resource.data.sleepHours <= 24
          && request.resource.data.mood is number
          && request.resource.data.mood >= 1
          && request.resource.data.mood <= 5
          && request.resource.data.screenTimeHours is number
          && request.resource.data.screenTimeHours >= 0
          && request.resource.data.studyHours is number
          && request.resource.data.studyHours >= 0;
        // Students cannot update or delete logs (immutable)
        allow update, delete: if false;
      }

      // Predictions (read-only — only Cloud Functions write)
      match /predictions/{predId} {
        allow read: if isOwner(studentId) || isTeacher();
        allow write: if false;
      }

      // Metrics (read-only — only Cloud Functions write)
      match /metrics/current {
        allow read: if isOwner(studentId) || isTeacher();
        allow write: if false;
      }
    }

    // === Teachers Collection ===
    match /teachers/{teacherId} {
      allow read: if isOwner(teacherId) || isTeacher();
      allow create: if isOwner(teacherId) && isTeacher();
      allow update: if isOwner(teacherId) && isTeacher();
    }

    // === Approved Teachers (admin-only via Console) ===
    match /approvedTeachers/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // === Alerts ===
    match /alerts/{alertId} {
      allow read: if isTeacher();
      // Only Cloud Functions create alerts
      allow create: if false;
      // Teachers can update alert status and actions
      allow update: if isTeacher();
      allow delete: if false;
    }

    // === Interventions ===
    match /interventions/{noteId} {
      // Both teachers and students can read (students see mentor actions)
      allow read: if isAuth();
      allow create: if isTeacher()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.studentId is string;
      allow update: if isTeacher()
        && resource.data.teacherId == request.auth.uid;
      allow delete: if false;
    }

    // === Notifications ===
    match /notifications/{notifId} {
      // Users can read and update (mark read) their own notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      // Only Cloud Functions create notifications
      allow create: if false;
      allow delete: if false;
    }
  }
}
